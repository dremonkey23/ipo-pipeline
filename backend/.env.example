# IPO Pipeline Configuration
PORT=3002
JWT_SECRET=your_secret_here
SEC_USER_AGENT=YourCompany your@email.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Scraping intervals (cron expressions)
IPO_SCRAPE_INTERVAL=0 * * * *

# Render deployment
# RENDER=true
# DB_PATH=ipo-pipeline.db
