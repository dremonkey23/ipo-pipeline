# IPO Pipeline Configuration
NODE_ENV=development
PORT=3002

# REQUIRED in production — generate a strong random secret
JWT_SECRET=your_secret_here

# SEC EDGAR requires a User-Agent with contact info
SEC_USER_AGENT=YourCompany your@email.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Scraping intervals (cron expressions)
IPO_SCRAPE_INTERVAL=0 * * * *

# Render deployment (set automatically by Render)
# RENDER=true
# DB_PATH=ipo-pipeline.db
